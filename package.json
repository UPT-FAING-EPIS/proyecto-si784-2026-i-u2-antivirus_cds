{
  "name": "rustguard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "concurrently \"vite --port 5173 --strictPort\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.rustguard.app",
    "productName": "RustGuard",
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "public/icon.png",
      "target": ["nsis"]
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "chokidar": "^4.0.3",
    "lucide-react": "^0.473.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.1",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
